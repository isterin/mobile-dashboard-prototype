# Domain
# This would be set to the production domain with an env var on deployment
DOMAIN=localhost

# Used by the backend to generate links to the frontend
FRONTEND_HOST=http://localhost:5173

# Environment: local, staging, production
ENVIRONMENT=local

PROJECT_NAME="Mobile Market Analysis Dashboard"
STACK_NAME=mobile-market-analysis-dashboard

# Backend
BACKEND_CORS_ORIGINS="http://localhost,http://localhost:5173,https://localhost,https://localhost:5173"

# Postgres
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=marketanalysis
POSTGRES_USER=marketanalysis
POSTGRES_PASSWORD=marketanalysis

SENTRY_DSN=
